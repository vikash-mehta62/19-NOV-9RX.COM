# Server Configuration
PORT=4000
NODE_ENV=development

# Database (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/9rx

# Supabase Configuration (for email tracking & webhooks)
SUPABASE_URL=https://qiaetxkxweghuoxyhvml.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# Automation terminal logger (optional)
AUTOMATION_TERMINAL_LOGS=true
AUTOMATION_LOG_POLL_MS=5000

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# Admin Notification Email
ADMIN_EMAIL=admin@9rx.com

# Authorize.Net Payment Gateway
AUTHORIZE_NET_API_LOGIN_ID=your-api-login-id
AUTHORIZE_NET_TRANSACTION_KEY=your-transaction-key

# FortisPay ACH Gateway (optional fallback if not using saved admin settings)
FORTIS_API_URL=https://api.fortispay.com/v2
FORTIS_SANDBOX_API_URL=
FORTIS_PRODUCTION_API_URL=
FORTIS_DEVELOPER_ID=your-fortis-developer-id
FORTIS_USER_ID=your-fortis-user-id
FORTIS_USER_API_KEY=your-fortis-user-api-key
FORTIS_LOCATION_ID=your-fortis-location-id
FORTIS_PRODUCT_TRANSACTION_ID_ACH=your-fortis-ach-product-id
FORTIS_SMOKE_ACCOUNT_NUMBER=your-sandbox-account-number
FORTIS_SMOKE_ROUTING_NUMBER=your-sandbox-routing-number
FORTIS_SMOKE_ACCOUNT_HOLDER_NAME=Sandbox ACH Test
FORTIS_SMOKE_ACCOUNT_TYPE=checking
FORTIS_SMOKE_AMOUNT=1.11
FORTIS_SMOKE_ALLOW_NON_SANDBOX=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
EMAIL_RATE_LIMIT_MAX=10

# Email Provider Webhook Secrets (optional - for signature verification)
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
SENDGRID_WEBHOOK_SECRET=your-sendgrid-webhook-secret

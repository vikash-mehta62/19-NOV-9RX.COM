# =========================
# SERVER
# =========================
PORT=4001

# =========================
# DATABASE
# =========================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/database-name

# =========================
# MAIL (GMAIL SMTP)
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false

MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-specific-password

MAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# =========================
# AUTHORIZE.NET
# =========================
AUTHORIZE_NET_API_LOGIN_ID=your-api-login-id
AUTHORIZE_NET_TRANSACTION_KEY=your-transaction-key

# =========================
# FORTISPAY ACH
# Optional fallback if credentials are not loaded from Supabase payment_settings
# =========================
FORTIS_API_URL=https://api.fortispay.com/v2
FORTIS_SANDBOX_API_URL=
FORTIS_PRODUCTION_API_URL=
FORTIS_DEVELOPER_ID=your-fortis-developer-id
FORTIS_USER_ID=your-fortis-user-id
FORTIS_USER_API_KEY=your-fortis-user-api-key
FORTIS_LOCATION_ID=your-fortis-location-id
FORTIS_PRODUCT_TRANSACTION_ID_ACH=your-fortis-ach-product-id
FORTIS_SMOKE_ACCOUNT_NUMBER=your-sandbox-account-number
FORTIS_SMOKE_ROUTING_NUMBER=your-sandbox-routing-number
FORTIS_SMOKE_ACCOUNT_HOLDER_NAME=Sandbox ACH Test
FORTIS_SMOKE_ACCOUNT_TYPE=checking
FORTIS_SMOKE_AMOUNT=1.11
FORTIS_SMOKE_ALLOW_NON_SANDBOX=false

# =========================
# QUICKBOOKS
# =========================
QUICK_CLIENT_ID=your-quickbooks-client-id
QUICK_CLIENT_SECRET=your-quickbooks-client-secret
QUICK_AUTH=your-quickbooks-auth-token
QUICK_REAL=your-quickbooks-realm-id
QUICKBOOK_REFRESH_TOKEN=your-quickbooks-refresh-token

# =========================
# SUPABASE
# =========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================
# RATE LIMITING
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
EMAIL_RATE_LIMIT_MAX=10

# =========================
# SECURITY
# =========================
NODE_ENV=production
